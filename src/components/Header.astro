---

<header class="header" id="header">
  <div class="container header-container">
    <a href="/" class="header-brand" id="header-logo">
      <img src="/logo-icon.png" alt="Margarit Icon" class="brand-icon" />
      <img src="/margarit-logo.webp" alt="Margarit" class="brand-wordmark" />
    </a>
    
    <nav class="nav">
      <a href="#menu" class="nav-link active">Menú</a>
      <a href="#reserva" class="nav-link">Reserves</a>
      <a href="#contacte" class="nav-link">Contacte</a>
    </nav>
  </div>
</header>

<style>
  .header {
    background-color: transparent;
    padding: 1.5rem 0 0.5rem 0;
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 10;
    transition: all 0.4s ease;
  }

  .header.scrolled {
    background-color: var(--color-bg);
    padding: 0.8rem 0 0.5rem 0;
    border-bottom: 1px solid var(--color-lines);
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 1;
    transition: all 0.4s ease;
    text-decoration: none;
  }

  .brand-wordmark {
    height: 22px;
    width: auto;
    object-fit: contain;
    opacity: 0;
    transition: all 0.4s ease;
    transform: translateX(-10px);
  }

  .header.scrolled .brand-wordmark {
    opacity: 0.85;
    transform: translateX(0);
  }

  .header-brand:hover .brand-wordmark {
    opacity: 1;
  }

  .brand-icon {
    width: 80px;
    height: 80px;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .header.scrolled .brand-icon {
    width: 50px;
    height: 50px;
  }

  .header.scrolled .brand-wordmark {
    opacity: 0.85;
  }

  .header-brand:hover .brand-icon {
    transform: rotate(15deg);
  }

  .nav {
    display: flex;
    gap: 3rem;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
    position: relative;
    padding-bottom: 0.2rem;
    text-decoration: none;
    opacity: 0.7;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--color-accent);
    opacity: 1;
  }

  .nav-link.active::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .header {
      padding: 1.5rem 0;
    }

    .header.scrolled {
      padding: 1rem 0;
    }

    .header-container {
      flex-direction: column;
      gap: 1.2rem;
      text-align: center;
    }

.brand-icon {
      width: 85px;
      height: 85px;
    }

    .nav {
      gap: 1.5rem;
      margin-top: 0;
    }
  }
</style>

<script is:inline>
  function initScrollHeader() {
    const header = document.getElementById('header');
    if (!header) return;
    
    const checkScroll = () => {
      if (window.scrollY > 50) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };
    
    window.addEventListener('scroll', checkScroll);
    checkScroll();
  }

  document.addEventListener('DOMContentLoaded', initScrollHeader);
</script>
