---

<header class="header" id="header">
  <div class="container header-container">
    <div class="header-logo" id="header-logo"></div>
    
    <nav class="nav">
      <a href="#menu" class="nav-link active">Menú</a>
      <a href="#reserva" class="nav-link">Reserves</a>
      <a href="#contacte" class="nav-link">Contacte</a>
    </nav>
  </div>
</header>

<style>
  .header {
    background-color: transparent;
    padding: 0.8rem 0 0.4rem 0;
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 10;
    transition: all 0.4s ease;
  }

  .header.scrolled {
    background-color: var(--color-bg);
    padding: 0.5rem 0 0.3rem 0;
    border-bottom: 1px solid var(--color-lines);
  }

  .header.scrolled .nav {
    margin-top: 10px;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-logo {
    max-width: 0;
    overflow: hidden;
    opacity: 0;
    transition: all 0.4s ease;
  }

  .header-logo::before {
    content: "MARGARIT";
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    white-space: nowrap;
  }

  .header.scrolled .header-logo {
    max-width: 200px;
    opacity: 1;
  }

  .header.scrolled .header-logo::before {
    font-size: 0.95rem;
  }

  .nav {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    margin-top: 12px;
  }

  .nav-link {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text);
    position: relative;
    padding-bottom: 0.2rem;
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav-link.active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-accent);
  }

  /* Responsive */
  @media (max-width: 600px) {
    .header {
      padding: 1.5rem 0;
    }

    .header.scrolled {
      padding: 1rem 0 0.75rem 0;
    }

    .header.scrolled .header-logo {
      max-width: 160px;
    }

    .header.scrolled .nav {
      margin-top: 10px;
    }

    .header-container {
      flex-direction: column;
      gap: 1.2rem;
      text-align: center;
    }

    .nav {
      gap: 1.5rem;
      margin-top: 0;
    }
  }
</style>

<script is:inline>
  function initScrollHeader() {
    const header = document.getElementById('header');
    if (!header) return;
    
    const checkScroll = () => {
      if (window.scrollY > 100) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };
    
    window.addEventListener('scroll', checkScroll);
    checkScroll();
  }

  document.addEventListener('DOMContentLoaded', initScrollHeader);
</script>
