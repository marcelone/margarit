<footer class="footer" id="contacte">
  <div class="container footer-container">
    <div class="footer-col col-napm">
      <p class="napm-name">MARGARIT</p>
      <p class="napm-address">Carrer Margarit, 15<br/>08004 Barcelona</p>
      <a href="tel:+34933104598" class="napm-phone">+34 933 10 45 98</a>
      <br/>
      <a href="mailto:reservas@margarit.info" class="napm-email">reservas@margarit.info</a>
    </div>
    
    <div class="footer-col col-map">
<div class="map-wrapper">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d369.4851294657961!2d2.161187379339507!3d41.37261693859655!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12a4a302460c7da1%3A0x3a3a7cc8582ac2e1!2sMargarit%20restaurant!5e0!3m2!1ses!2ses!4v1779705336935!5m2!1ses!2ses"
          class="map-iframe"
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicació de Margarit">
        </iframe>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--color-lines); padding: 4rem 0 2rem 0; margin-top: 2rem; width: 100%; background-color: transparent; }
  .footer-container { display: grid; grid-template-columns: auto 1fr; gap: 3rem; width: 100%; align-items: start; }
  .col-napm { align-items: flex-start; }
  .napm-name { font-family: var(--font-display); font-size: 1rem; letter-spacing: 0.15em; color: var(--color-accent); margin-bottom: 0.8rem; }
  .napm-address { font-family: var(--font-serif); font-size: 0.95rem; color: var(--color-text); line-height: 1.5; margin-bottom: 1.2rem; }
  .napm-phone { font-family: var(--font-serif); font-size: 0.95rem; color: var(--color-text); line-height: 1.5; margin-bottom: 0.4rem; }
  .napm-email { font-family: var(--font-serif); font-size: 0.95rem; color: var(--color-text); line-height: 1.5; }
  .napm-email { border-bottom: 1px solid transparent; }
  .napm-email:hover { border-color: var(--color-text); }
.col-map { width: 100%; pointer-events: auto; position: relative; z-index: 1; }
  .map-wrapper {
    width: 100%;
    height: 200px;
    overflow: hidden;
    border: 1px solid var(--color-lines);
    pointer-events: auto;
    position: relative;
    z-index: 1;
  }
  .map-iframe {
    width: 100%;
    height: 100%;
    filter: grayscale(80%) sepia(20%) brightness(1.05) contrast(0.9);
    transition: filter 0.3s ease;
    pointer-events: auto;
    position: relative;
    z-index: 1;
  }
  .map-iframe:hover {
    filter: grayscale(60%) sepia(15%) brightness(1.05) contrast(0.95);
  }
  @media (max-width: 900px) { .footer-container { flex-direction: column; gap: 2rem; } .col-map { justify-content: center; } .map-wrapper { max-width: 100%; height: 200px; } }
  @media (max-width: 600px) { .footer { padding: 3rem 0 2rem 0; } .footer-container { justify-content: center; align-items: center; } .col-napm { align-items: center; } }
</style>