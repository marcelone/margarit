---
---

<section class="reserva-section" id="reserva">
  <div class="container reserva-container">
    <div class="reserva-grid">
      <div class="reserva-col">
        <h2 class="reserva-title">Reserva la teva taula</h2>
        <p class="reserva-subtitle">Menú de temporada, vins naturals i servei proper.</p>
        
        <div class="schedule-grid">
          <div class="schedule-item">
            <span class="day">DL</span>
            <span class="hours">20–22:30</span>
          </div>
          <div class="schedule-item">
            <span class="day">DT</span>
            <span class="hours closed">Tancat</span>
          </div>
          <div class="schedule-item">
            <span class="day">DC</span>
            <span class="hours">20–22:30</span>
          </div>
          <div class="schedule-item">
            <span class="day">DJ</span>
            <span class="hours">20–22:30</span>
          </div>
          <div class="schedule-item">
            <span class="day">DV</span>
            <span class="hours">13–15:30<br/>20–22:30</span>
          </div>
          <div class="schedule-item">
            <span class="day">DS</span>
            <span class="hours">11–15:30<br/>20–22:30</span>
          </div>
          <div class="schedule-item">
            <span class="day">DG</span>
            <span class="hours">11–15:30<br/>20–22:30</span>
          </div>
        </div>
        
        <div class="reserva-action">
          <button class="btn-filled btn-reserva" id="reserva-modal-btn">
            RESERVAR ARA
          </button>
        </div>
      </div>
      
      <div class="reviews-col">
        <div class="press-col">
          <div class="press-carousel">
            <div class="press-quote" data-active="true">
              <span class="press-mark">"</span>
              <p class="press-text">El Mediterráneo también era esto</p>
              <span class="press-source">Hule y Mantel</span>
            </div>
            <div class="press-quote">
              <span class="press-mark">"</span>
              <p class="press-text">El local es una delicia y la cocina inclasificable</p>
              <span class="press-source">Gastronomistas</span>
            </div>
            <div class="press-quote">
              <span class="press-mark">"</span>
              <p class="press-text">Margarit, el original restaurante de Poble Sec</p>
              <span class="press-source">Fodie</span>
            </div>
            <div class="press-quote">
              <span class="press-mark">"</span>
              <p class="press-text">Un restaurante de base griega que juega con la amplitud culinaria del Mediterráneo.</p>
              <span class="press-source">Time Out</span>
            </div>
          </div>
          <div class="press-nav">
            <button class="press-btn prev" aria-label="Anterior">
              <svg viewBox="0 0 24 24" width="16" height="16"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
            </button>
            <div class="press-dots">
              <button class="press-dot active" aria-label="1"></button>
              <button class="press-dot" aria-label="2"></button>
              <button class="press-dot" aria-label="3"></button>
              <button class="press-dot" aria-label="4"></button>
            </div>
            <button class="press-btn next" aria-label="Següent">
              <svg viewBox="0 0 24 24" width="16" height="16"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
            </button>
          </div>
        </div>
        <div class="rating-badges">
          <img src="/google-reviews.png" alt="Google Reviews" class="badge-img" />
          <img src="/fork-reviews.png" alt="TheFork Reviews" class="badge-img" />
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Modal Popup -->
<div class="modal-overlay" id="reserva-modal-overlay">
  <div class="modal-content">
    <button class="modal-close" id="reserva-modal-close" aria-label="Tancar">
      <svg viewBox="0 0 24 24" width="24" height="24"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
    </button>
    <div class="modal-disclaimer">
      <p class="disclaimer-title">Informació important per a les reserves</p>
      <div class="collapsable open">
        <button class="collapsable-header" aria-expanded="true">
          <span>Experiència i tipus d'espai</span>
          <svg class="chevron" viewBox="0 0 24 24" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
        </button>
        <div class="collapsable-content">
          <p>La nostra proposta està pensada per gaudir d'una experiència gastronòmica tranquil·la, íntima i molt vinculada al ritme de la cuina vista.</p>
          <p>Per la naturalesa de l'espai, la distribució de la sala i el funcionament del servei, no és l'entorn més adequat per a nens petits, carrets infantils o grups nombrosos.</p>
        </div>
      </div>
      <div class="collapsable">
        <button class="collapsable-header" aria-expanded="false">
          <span>Reserves especials o grups nombrosos</span>
          <svg class="chevron" viewBox="0 0 24 24" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
        </button>
        <div class="collapsable-content">
          <p>En el cas de reserves que no s'ajustin a aquestes recomanacions, us convidem a contactar-nos directament per poder valorar la millor opció i gestionar personalment una ubicació adequada, de manera que puguem atendre-us amb la comoditat que mereixeu.</p>
        </div>
      </div>
      <div class="collapsable">
        <button class="collapsable-header" aria-expanded="false">
          <span>Puntualitat</span>
          <svg class="chevron" viewBox="0 0 24 24" width="20" height="20"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
        </button>
        <div class="collapsable-content">
          <p>Us agraïm també que respecteu l'horari compromès en el moment de la reserva. La puntualitat és important per poder oferir un bon servei a tots els clients i evitar desajustos en l'organització de la sala i la cuina.</p>
        </div>
      </div>
    </div>
    <iframe 
      src="https://widget.thefork.com/a6a35ded-695a-412c-9dc3-ceb69f04795c"
      allow="payment *"
      style="width: 100%; min-height: 800px; border: none; overflow: scroll;"
      title="Reserves TheFork">
    </iframe>
  </div>
</div>

<style>
  .reserva-section {
    padding: 7rem 0;
    background-color: transparent;
    width: 100%;
  }

  .reserva-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .reserva-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  .reserva-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .reserva-title {
    font-size: 2.5rem;
    color: var(--color-accent);
    margin-bottom: 0.8rem;
    letter-spacing: 0.15em;
  }

  .reserva-subtitle {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-text);
    margin-bottom: 3.5rem;
    font-weight: 400;
  }

  .schedule-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 2.5rem;
    margin-bottom: 4rem;
  }

  .schedule-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
    min-width: 60px;
  }

  .day {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-lines);
    padding-bottom: 0.2rem;
    margin-bottom: 0.2rem;
    width: 100%;
  }

  .hours {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-text);
    line-height: 1.4;
  }

  .hours.closed {
    font-style: italic;
    opacity: 0.5;
  }

.reserva-action {
    display: inline-block;
  }

  .btn-reserva {
    box-shadow: none;
    font-size: 1.15rem;
    padding: 1rem 3.5rem;
  }

  .reviews-col {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    min-height: 500px;
  }

  .press-col {
    flex: 12;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    padding: 2rem;
    border: 1px solid var(--color-lines);
    min-height: 380px;
  }

  .press-carousel {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    flex: 1;
  }

  .press-quote {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    text-align: center;
  }

  .press-quote[data-active="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  .press-mark {
    font-family: var(--font-serif);
    font-size: 4rem;
    line-height: 0;
    color: var(--color-accent);
    opacity: 0.3;
    display: block;
    margin-bottom: 1rem;
  }

  .press-text {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-style: italic;
    font-weight: 300;
    color: var(--color-text);
    line-height: 1.35;
    margin-bottom: 1.5rem;
  }

  .press-source {
    font-family: var(--font-display);
    font-size: 0.95rem;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    text-transform: uppercase;
  }

  .press-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .press-btn {
    background: transparent;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0;
    opacity: 0.4;
    transition: opacity 0.3s;
  }

  .press-btn:hover {
    opacity: 1;
  }

  .press-dots {
    display: flex;
    gap: 0.8rem;
  }

  .press-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: 1px solid var(--color-accent);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s;
  }

  .press-dot.active {
    background: var(--color-accent);
    transform: scale(1.2);
  }

  .press-dot:hover {
    background: var(--color-accent);
  }

  .rating-badges {
    flex: 2;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    padding: 1.5rem;
    border-top: 1px solid var(--color-lines);
  }

  .badge-img {
    width: 160px;
    height: auto;
    object-fit: contain;
  }

  /* Modal Styles */
  .modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    z-index: 9999;
    justify-content: center;
    align-items: center;
    padding: 2rem;
  }

  .modal-overlay.active {
    display: flex;
  }

  .modal-content {
    background: var(--color-bg);
    max-width: 800px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    padding: 3rem;
    border: 1px solid var(--color-lines);
  }

  .modal-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    opacity: 0.6;
    transition: opacity 0.3s;
    padding: 0;
  }

  .modal-close:hover {
    opacity: 1;
  }

  .modal-disclaimer {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-lines);
  }

  .disclaimer-title {
    font-family: var(--font-display) !important;
    font-size: 1.25rem !important;
    letter-spacing: 0.15em;
    color: var(--color-accent) !important;
    text-transform: uppercase;
    margin-bottom: 1.5rem !important;
  }

  .collapsable {
    border-bottom: 1px solid var(--color-lines);
  }

  .collapsable:first-child {
    border-top: 1px solid var(--color-lines);
  }

  .collapsable-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 1.2rem 0;
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    text-transform: uppercase;
    text-align: left;
  }

  .collapsable-header .chevron {
    transition: transform 0.3s ease;
  }

  .collapsable.open .collapsable-header .chevron {
    transform: rotate(180deg);
  }

  .collapsable-content {
    display: none;
    padding-bottom: 1.2rem;
  }

  .collapsable.open .collapsable-content {
    display: block;
  }

  .collapsable-content p {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 0.8rem;
  }

  .collapsable-content p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .reserva-section {
      padding: 4rem 0;
    }

    .reserva-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .reserva-col {
      align-items: center;
      text-align: center;
    }

    .schedule-grid {
      justify-content: center;
      gap: 1.5rem;
    }

    .press-col {
      padding: 2rem 1rem;
    }

    .press-text {
      font-size: 1.6rem;
    }

    .modal-content {
      padding: 1.5rem;
    }
  }
</style>

<script is:inline>
  function initCollapsables() {
    document.querySelectorAll('.collapsable-header').forEach(header => {
      header.onclick = () => {
        const collapsable = header.closest('.collapsable');
        const isOpen = collapsable.classList.contains('open');
        document.querySelectorAll('.collapsable').forEach(c => c.classList.remove('open'));
        document.querySelectorAll('.collapsable-header').forEach(h => h.setAttribute('aria-expanded', 'false'));
        if (!isOpen) {
          collapsable.classList.add('open');
          header.setAttribute('aria-expanded', 'true');
        }
      };
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const pressQuotes = document.querySelectorAll('.press-quote');
    const pressDots = document.querySelectorAll('.press-dot');
    const pressPrev = document.querySelector('.press-btn.prev');
    const pressNext = document.querySelector('.press-btn.next');
    let currentPress = 0;
    const total = pressQuotes.length;

    function showPress(index) {
      pressQuotes.forEach((q, i) => q.setAttribute('data-active', i === index ? 'true' : 'false'));
      pressDots.forEach((d, i) => d.classList.toggle('active', i === index));
      currentPress = index;
    }

    pressPrev?.addEventListener('click', () => {
      currentPress = (currentPress - 1 + total) % total;
      showPress(currentPress);
    });

    pressNext?.addEventListener('click', () => {
      currentPress = (currentPress + 1) % total;
      showPress(currentPress);
    });

    pressDots.forEach((dot, i) => dot.addEventListener('click', () => showPress(i)));

    const reservaModalBtn = document.getElementById('reserva-modal-btn');
    const reservaModalOverlay = document.getElementById('reserva-modal-overlay');
    const reservaModalClose = document.getElementById('reserva-modal-close');

    function openReservaModal() {
      reservaModalOverlay?.classList.add('active');
      document.body.style.overflow = 'hidden';
      initCollapsables();
    }

    function closeReservaModal() {
      reservaModalOverlay?.classList.remove('active');
      document.body.style.overflow = '';
    }

    reservaModalBtn?.addEventListener('click', openReservaModal);
    reservaModalClose?.addEventListener('click', closeReservaModal);
    reservaModalOverlay?.addEventListener('click', (e) => {
      if (e.target === reservaModalOverlay) closeReservaModal();
    });

    initCollapsables();
  });
</script>